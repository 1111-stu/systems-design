{
  "name": "drizzle-migration-cicd-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "db:build": "esbuild db/migrate.ts --bundle --platform=node --format=esm --external:pg-native --outfile=dist/migrate.js",
    "db:migrate:run": "tsx db/migrate.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/pg": "^8.15.1",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
